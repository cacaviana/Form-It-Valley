# FlowQuote / Forms IT Valley — backend (.env.example)
# Copie para .env e preencha. NUNCA commite valores reais.

# --- MongoDB ---
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net
# Producao usa o database configurado no App Service (ver appsettings do formsitvalleybackend)
MONGODB_DATABASE=flowquote

# --- App ---
APP_NAME=FlowQuote Backend
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=["*"]

# --- Petra Suite (identidade central / multitenant) ---
# O login do Forms e um proxy fino para a plataforma. O JWT e emitido pela
# suite e validado aqui com a MESMA chave.
# Valor real da chave (producao): Azure Key Vault
#   az keyvault secret show --vault-name kv-api-key-itvalley -n petra-jwt-secret-key --query value -o tsv
JWT_SECRET_KEY=<petra-jwt-secret-key do Key Vault — minimo 32 chars>
PLATFORM_AUTH_URL=https://suite-api.petrasuite.ai

# --- IA ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Integracoes (opcionais) ---
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GENESIS_WEBHOOK_URL=
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_API_URL=
RESEND_API_KEY=
