# FlowQuote Backend - Environment Variables
# Copie para .env e preencha com seus valores

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster1
MONGODB_DATABASE=flowquote

# App
APP_NAME=FlowQuote Backend
APP_VERSION=1.0.0
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# OpenAI (default)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) - opcional, use AI_PROVIDER=anthropic para ativar
AI_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
